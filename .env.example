# Backend-only Supabase configuration.
# Copy to .env locally, or set these in Replit Secrets / deployment env vars.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional fallback if you are not using a service-role key.
# SUPABASE_ANON_KEY=<anon-key>

# Google Sheets OAuth2 credentials (for dynamic data ingestion)
GSHEETS_CLIENT_ID=<google-oauth-client-id>
GSHEETS_CLIENT_SECRET=<google-oauth-client-secret>
GSHEETS_REFRESH_TOKEN=<google-oauth-refresh-token>

