# Backend-only Supabase configuration.
# Copy to .env locally, or set these in Replit Secrets / deployment env vars.

# Required for protected write actions on deployed environments.
# Set this in Railway, then enter the same value once in the browser when prompted.
SCHEDULER_ADMIN_TOKEN=<strong-admin-token>

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional fallback if you are not using a service-role key.
# SUPABASE_ANON_KEY=<anon-key>

# Google Sheets OAuth2 credentials (for dynamic data ingestion)
GSHEETS_CLIENT_ID=<google-oauth-client-id>
GSHEETS_CLIENT_SECRET=<google-oauth-client-secret>
GSHEETS_REFRESH_TOKEN=<google-oauth-refresh-token>

# AI provider API keys. Configure at least one of DEEPSEEK_API_KEY,
# OPENROUTER_API_KEY, or OPENAI_API_KEY. The schedule_config.json
# settings UI no longer persists keys to disk; env wins over config.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_BACKUP_MODEL=z-ai/glm-4.5-air:free

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

AI_REQUEST_TIMEOUT_SECONDS=30
AI_RATE_LIMIT_RETRIES=3
